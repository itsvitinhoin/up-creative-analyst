# Meta Marketing API
META_ACCESS_TOKEN=your_meta_access_token_here
META_API_VERSION=v23.0

# PostgreSQL — use Supabase pooler URL (port 6543) for Vercel/serverless
# Note: if your password contains @ it must be URL-encoded as %40
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection (port 5432) — used by Prisma for migrations only
DIRECT_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Set to true to use mock data fallback when DB/Meta API is unavailable
DEV_FALLBACK_MOCKS=false
